{
	"name": "@uuxxx/fsm-vue",
	"version": "0.0.1",
	"description": "Vue bindings for @uuxxx/fsm",
	"keywords": [
		"composables",
		"fsm",
		"state machine",
		"vue"
	],
	"homepage": "https://github.com/uuxxx/fsm/blob/main/packages/vue/README.md",
	"license": "MIT",
	"author": "Artem Tryapichnikov <golysheeet@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/uuxxx/fsm.git",
		"directory": "packages/vue"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rolldown -c rolldown.config.ts",
		"check:types": "tsc --noEmit"
	},
	"dependencies": {
		"@uuxxx/fsm": "workspace:*"
	},
	"devDependencies": {
		"@swc/core": "^1.13.5",
		"rolldown": "^1.0.0-beta.41",
		"rolldown-plugin-dts": "^0.22.1",
		"rollup-plugin-swc3": "^0.12.1",
		"tslib": "^2.8.1",
		"vue": "^3.5.0"
	},
	"peerDependencies": {
		"vue": ">=3"
	}
}
