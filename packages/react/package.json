{
	"name": "@uuxxx/fsm-react",
	"version": "0.1.2",
	"description": "React bindings for @uuxxx/fsm",
	"keywords": [
		"fsm",
		"hooks",
		"react",
		"state machine"
	],
	"homepage": "https://github.com/uuxxx/fsm/blob/main/packages/react/README.md",
	"license": "MIT",
	"author": "Artem Tryapichnikov <golysheeet@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/uuxxx/fsm.git",
		"directory": "packages/react"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rolldown -c rolldown.config.ts",
		"check:types": "tsc --noEmit"
	},
	"dependencies": {
		"@uuxxx/fsm": "workspace:*"
	},
	"devDependencies": {
		"@swc/core": "^1.13.5",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.2.3",
		"jsdom": "^29.0.1",
		"react": "^19.1.0",
		"react-dom": "^19.2.4",
		"rolldown": "^1.0.0-beta.41",
		"rolldown-plugin-dts": "^0.22.1",
		"rollup-plugin-swc3": "^0.12.1",
		"tslib": "^2.8.1"
	},
	"peerDependencies": {
		"react": ">=18"
	}
}
